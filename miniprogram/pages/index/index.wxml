    <view class="hero__address-text">
      <text>CALLE DE FERNANDO EL</text>
      <text>CATÓLICO 84 BAJO 28015 MADRID</text>
    </view>
  </view>

  <!-- About Section -->
  <view class="section">
    <text class="section__title">马德里最佳电竞馆</text>
    <text class="about-subtitle">西班牙华人玩家都来这里</text>
    <view class="about-content">
      <text class="about-text">COLIZEUM MADRID 是马德里华人圈最火的电竞馆，配置顶级，环境舒适。</text>
      <text class="about-text">全馆配备 RTX 4090 显卡，144Hz 电竞屏，机械键盘鼠标，想玩什么都能带飞。</text>
      <text class="about-text">网速超快，延迟超低，开黑打团再也不用担心卡顿掉线。</text>
      <text class="about-text">一个人来练技术，约朋友组队开黑，或者办比赛活动，都没问题！</text>
    </view>
    <button class="button__book button__book-centered" open-type="contact">预订</button>
  </view>

  <!-- Promo Section -->
  <view class="section">
    <text class="section__title">优惠活动</text>
    <swiper 
      class="promo-swiper" 
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.3)"
      indicator-active-color="#ffee00"
      autoplay="{{true}}"
      interval="5000"
      circular="{{true}}"
    >
      <swiper-item>
        <view class="promo-slide">
          <image class="promo-image" src="/promos/1.png" mode="aspectFit" />
        </view>
      </swiper-item>
      <swiper-item>
        <view class="promo-slide">
          <image class="promo-image" src="/promos/2.png" mode="aspectFit" />
        </view>
      </swiper-item>
      <swiper-item>
        <view class="promo-slide">
          <image class="promo-image" src="/promos/3.png" mode="aspectFit" />
        </view>
      </swiper-item>
      <swiper-item>
        <view class="promo-slide">
          <image class="promo-image" src="/promos/4.png" mode="aspectFit" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- Photos Section -->
  <view class="section">
    <text class="section__title">场馆照片</text>
    <view class="photos-grid">
      <view class="photo-item">
        <image class="photo-image" src="/assets/b971e15c639ef1e4bdd7.jpg" mode="aspectFill" />
      </view>
      <view class="photo-item">
        <image class="photo-image" src="/assets/f49ba04c3ca84802a1e3.jpg" mode="aspectFill" />
      </view>
      <view class="photo-item">
        <image class="photo-image" src="/assets/7f58ac0c39a97a4d8ab2.jpg" mode="aspectFill" />
      </view>
      <view class="photo-item">
        <image class="photo-image" src="/assets/7c4b959dc4c02ef8be37.jpg" mode="aspectFill" />
      </view>
      <view class="photo-item">
        <image class="photo-image" src="/assets/797cd758842575077029.jpg" mode="aspectFill" />
      </view>
      <view class="photo-item">
        <image class="photo-image" src="/assets/1788d8e073bf2f0e5e5c.jpg" mode="aspectFill" />
      </view>
    </view>
  </view>

  <!-- WeChat Section -->
  <view class="section">
    <view class="wechat-section">
      <button class="wechat-card" open-type="contact">
        <view class="wechat-card-content">
          <text class="wechat-card-title">微信客服</text>
          <text class="wechat-card-subtitle">在线咨询 · 快速响应</text>
          <view class="wechat-card-action">点击联系 →</view>
        </view>
      </button>

      <button class="wechat-card wechat-card-secondary" bindtap="openWebview">
        <view class="wechat-card-content">
          <text class="wechat-card-title">微信公众号</text>
          <text class="wechat-card-subtitle">最新活动 · 优惠信息</text>
          <view class="wechat-card-action">点击关注 →</view>
        </view>
      </button>
    </view>
  </view>

  <!-- Map Section -->
  <view class="section">
    <text class="section__title">位置</text>
    <map 
      class="map-container"
      latitude="40.4345526"
      longitude="-3.7168796"
      markers="{{markers}}"
      show-location="{{true}}"
      scale="16"
      bindmarkertap="openLocation"
    />
    <view class="map-address">
      <text class="map-address-title">COLIZEUM MADRID</text>
      <text class="map-address-text">CALLE DE FERNANDO EL CATÓLICO 84 BAJO</text>
      <text class="map-address-text">28015 MADRID, ESPAÑA</text>
    </view>
  </view>
</scroll-view>
