.container {
  min-height: 100vh;
  background-color: #f5f5f7;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 15px 0 24px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.login-card {
  padding: 32px;
}

.login-header {
  text-align: center;
  margin-bottom: 32px;
}

.brand-title {
  font-size: 32px;
  font-weight: 700;
  color: var(--lumisa-dark);
  margin-bottom: 16px;
}

.page-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8px;
}

.page-desc {
  font-size: 14px;
  color: #666;
}

.form-group {
  margin-bottom: 16px;
}
