.container {
  height: 100vh;
  background-color: #f5f5f7;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: var(--header-bg);
  z-index: 100;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.header-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16px;
  position: relative;

  padding-bottom: 12px;
}

.header-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-main);
}

.swiper-dots {
  position: absolute;
  bottom: 4px;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 6px;
  padding-bottom: 4px;
}

.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #e2e8f0;
  transition: all 0.3s ease;
}

.dot.active {
  width: 16px;
  border-radius: 3px;
  background-color: #1e293b;
}

.content {
  flex: 1;
  padding: 16px;
  box-sizing: border-box;
}

.sticky-header-container {
  position: relative;
  z-index: 100;
  padding: 16px 16px 0 16px;
  background-color: #f5f5f7;
}

.full-page-swiper {
  flex: 1;

  width: 100%;
  height: 100%;
}

.content {
  flex: 1;
  height: 0;
  padding: 16px;
  box-sizing: border-box;
}

swiper-item {
  display: flex;
  flex-direction: column;
}

.contract-divider {
  height: 1px;
  background-color: #f1f5f9;
  margin: 0 16px;
}

.contract-action {
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  color: #2563eb;
  font-size: 13px;
  font-weight: 500;
}

.invoice-header {
  margin-bottom: 16px;
  padding: 0 4px;
  margin-top: 0;
}

.invoice-header-title {
  font-size: 18px;
  font-weight: 700;
  color: #1f2937;
}

.total-count {
  font-size: 14px;
  color: #9ca3af;
  margin-top: 4px;
}

.invoice-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.invoice-card {
  padding: 16px;
  margin: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.invoice-title {
  font-size: 15px;
  font-weight: 700;
  color: #1f2937;
}

.invoice-status {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 4px;
}

.invoice-status.paid {
  background-color: #e8f5e9;
  color: #4caf50;
}

.invoice-status.unpaid {
  background-color: #fff0f0;
  color: #ff3b30;
}

.card-row.date-row {
  margin-bottom: 8px;
}

.card-label {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 2px;
}

.card-value {
  font-size: 14px;
  color: #374151;
  font-weight: 500;
}

.card-row.period-row {
  margin-bottom: 12px;
}

.divider {
  height: 1px;
  background-color: #f3f4f6;
  margin: 0 -16px 12px -16px;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount {
  font-size: 18px;
  font-weight: 700;
  color: #1f2937;
}

.download-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background-color: #eff6ff;
  color: #2563eb;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
}

.loading-more,
.no-more {
  padding: 8px 16px;
  text-align: center;
  color: #999;
  font-size: 12px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 16px;
  flex: 1;
}

.empty-icon {
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: #999999;
  text-align: center;
}

.empty-login-btn {
  margin-top: 24px;
  padding: 10px 24px;
  background-color: var(--lumisa-dark-cyan);
  color: white;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
}
