.skeleton-container {
  padding: 0 4px;
  animation: fadeIn 0.3s ease;
}

.skeleton-header {
  margin-bottom: 16px;
  margin-top: 8px;
}

.skeleton-title {
  width: 120px;
  height: 24px;
  background: #e2e8f0;
  border-radius: 4px;
  margin-bottom: 8px;
  position: relative;
  overflow: hidden;
}

.skeleton-count {
  width: 80px;
  height: 14px;
  background: #e2e8f0;
  border-radius: 4px;
  position: relative;
  overflow: hidden;
}

.skeleton-card {
  height: 140px;
  background: #ffffff;
  border-radius: 12px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}

.skeleton-title::after,
.skeleton-count::after,
.skeleton-card::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.5),
    transparent
  );
  transform: translateX(-100%);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  100% {
    transform: translateX(100%);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
