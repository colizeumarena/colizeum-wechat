.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: var(--header-bg);
  z-index: 100;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.header-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: relative;
}

.back-btn {
  height: 100%;
  display: flex;
  align-items: center;
  
  padding-right: 16px;
}

.back-icon {
  display: block;
  
  transform: rotate(90deg);
}

.header-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-main);
}
