.faq-item {
  background-color: white;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
  border: 1px solid #f3f4f6;
}

.faq-question {
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 600;
  color: #1f2937;
  font-size: 15px;
}


.arrow-icon {
  margin-left: 8px;
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.arrow-icon.up {
  transform: rotate(180deg);
}

.faq-answer {
  padding: 0 16px 16px 16px;
  font-size: 14px;
  color: #4b5563;
  line-height: 1.6;
  border-top: 1px solid #f3f4f6;
  padding-top: 12px;
}
